# --- Server (orchestrator machine) ---
PORT=3000
DB_PATH=./data/agentOS.db
YOUTRACK_URL=https://libraryabout.youtrack.cloud
YOUTRACK_TOKEN=
YOUTRACK_PROJECT=PVF
GITHUB_TOKEN=

# --- Client (agent machines) ---
ORCHESTRATOR_URL=ws://192.168.1.100:3000/ws
AGENT_ID=agent-1
AGENT_ROLE=dev
CAPABILITIES=base,blender,unity
WORKSPACE_PATH=./workspace
GIT_USERNAME=agent-1
GIT_EMAIL=agent-1@libraryabout.com
GITHUB_REPO=org/pvf-project
ANTHROPIC_API_KEY=
# Command used to run the AI executor (defaults to "claude")
CLAUDE_CMD=claude

# claude CLI path (auto-detected by bootstrap)
# Windows: CLAUDE_PATH=C:\Users\<username>\.local\bin\claude.exe
# Linux/Mac: CLAUDE_PATH=/usr/local/bin/claude
CLAUDE_PATH=
